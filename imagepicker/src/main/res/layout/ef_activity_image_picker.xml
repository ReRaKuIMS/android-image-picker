<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- NOTE: Android 15+ Edge-to-Edge 用の Spacer。
         この View は system status bar の高さに動的に合わせ
         toolbar と重ならないようにする。 -->
    <View
        android:id="@+id/ef_status_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_alignParentTop="true"
        android:background="?attr/colorPrimaryDark" />

    <include
        android:id="@+id/toolbar"
        layout="@layout/ef_imagepicker_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ef_status_bar_spacer" />

    <FrameLayout
        android:id="@+id/ef_imagepicker_fragment_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar" />

</RelativeLayout>
